print
total = 0
while True:
    price = int(input("Введите цену товара (0 для выхода): "))
    if price == 0:
        break
    if price < 0        print("Ошибка цены")
        continue
    total += price

if total > 1000:
    total *= 0.9  # скидка 10%
    print(f"Итоговая сумма со скидкой: {total:.2f}")
else:
    print(f"Итоговая сумма: {total:.2f}")
